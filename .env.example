# Filesystem Pro — Environment Variables
# Copy this file to .env and adjust values as needed.
# Resolution priority: env vars > JSON config file (MCP_CONFIG_FILE) > defaults.

# ============================================================================
# SECURITY
# ============================================================================

# Roots Protocol — restrict filesystem access to client-declared roots.
# Enabled by default. Set to "false" to disable (unrestricted access,
# trusted dev environments only).
# Default: enabled
# MCP_ROOTS_RESTRICTION=true

# Staleness guard — reject edits to files modified outside the current session.
# Default: enabled
# MCP_STALENESS_GUARD=true

# ============================================================================
# CACHE
# ============================================================================

# Symbol cache (tree-sitter symbol lookups)
# Default: 100 entries, 60000 ms TTL
MCP_SYMBOL_CACHE_SIZE=100
MCP_SYMBOL_CACHE_TTL=60000

# AST cache (parsed syntax trees)
# Default: 25 entries, 60000 ms TTL
MCP_AST_CACHE_SIZE=25
MCP_AST_CACHE_TTL=60000

# Disable all caching (debugging only)
# Default: false
# MCP_CACHE_DISABLED=false

# ============================================================================
# UNDO STACK
# ============================================================================

# Max number of undo entries kept in memory
# Default: 100
# MCP_UNDO_STACK_SIZE=100

# Max bytes per undo entry before switching to diff patches (files >1MB not undoable)
# Default: 1000000
# MCP_UNDO_MAX_ENTRY_BYTES=1000000

# Directory for undo disk persistence (empty = no persistence)
# Default: "" (disabled)
# MCP_UNDO_PERSIST_DIR=/tmp/mcp-undo

# ============================================================================
# SEARCH (ripgrep)
# ============================================================================

# Max concurrent ripgrep processes
# Default: 8
# MCP_MAX_CONCURRENT_RG=8

# Ripgrep process timeout in ms
# Default: 10000
# MCP_RG_TIMEOUT_MS=10000

# Max bytes of ripgrep output before truncation (CWE-400 mitigation)
# Default: 2097152 (2 MB)
# MCP_MAX_SEARCH_OUTPUT_BYTES=2097152

# ============================================================================
# FILE OPERATIONS
# ============================================================================

# Max file size for read operations in bytes
# Default: 52428800 (50 MB)
# MCP_MAX_FILE_SIZE_BYTES=52428800

# Filesystem operation timeout in ms
# Default: 60000
# MCP_FS_TIMEOUT_MS=60000

# ============================================================================
# GRAMMARS (tree-sitter WASM)
# ============================================================================

# Custom directory for tree-sitter WASM grammar files
# Default: bundled in dist/grammars/
# GRAMMARS_DIR=/path/to/grammars

# ============================================================================
# CONFIG FILE
# ============================================================================

# Path to a JSON config file (merged with defaults, overridden by env vars)
# Default: none
# MCP_CONFIG_FILE=/path/to/mcp-filesystem.config.json

# ============================================================================
# DEBUGGING
# ============================================================================

# Enable debug logging
# Default: false
# MCP_DEBUG=false
# DEBUG_MCP=false
# DEBUG=false